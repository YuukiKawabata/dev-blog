---
import Base from "@layouts/Base.astro";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";
import { Image } from "astro:assets";
import config from "@config/config.json";
import { slugify } from "@utils/slug";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, categories, tags } =
  Astro.props;
---

<Base
  meta_title={title}
  description={description}
  image={heroImage}
  pubDate={pubDate}
  updatedDate={updatedDate}
  blogpost
>
  <article>
    <header class="mb-10">
      <div class="mb-5 flex items-center gap-3 text-xs uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">
        {
          categories?.slice(0, 1).map((category) => (
            <a
              href={`/categories/${slugify(category)}`}
              class="text-gray-500 transition-colors hover:text-indigo-700 dark:text-gray-400 dark:hover:text-indigo-300"
            >
              {category}
            </a>
          ))
        }
        <span class="text-gray-300 dark:text-gray-700">/</span>
        <FormattedDate date={pubDate} />
      </div>

      <h1 class="font-heading text-3xl font-semibold leading-tight tracking-tight text-gray-900 dark:text-white sm:text-4xl md:text-5xl">{title}</h1>

      <div class="mt-6 flex items-center gap-2.5 text-sm text-gray-500 dark:text-gray-400">
        <Image
          alt={config.author.name}
          class="h-7 w-7 rounded-full"
          width={50}
          height={50}
          src={config.author.avatar}
          decoding="async"
          loading="lazy"
        />
        <span class="font-medium text-gray-700 dark:text-gray-300">{config.author.name}</span>
      </div>
    </header>

    {
      heroImage && (
        <figure class="mb-10 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-800">
          <Image
            class="h-full w-full object-cover"
            src={heroImage}
            alt={title}
            width={960}
            height={480}
            decoding="async"
            loading="lazy"
          />
        </figure>
      )
    }

    <div class="prose prose-lg prose-neutral dark:prose-invert">
      <slot />
    </div>

    <div class="mt-12 border-t border-gray-200 pt-8 dark:border-gray-800">
      <div class="flex flex-wrap gap-x-4 gap-y-2">
      {
        tags?.map((tag) => (
          <a
            href={`/tags/${slugify(tag)}`}
            class="text-sm text-gray-500 transition-colors hover:text-indigo-700 dark:text-gray-400 dark:hover:text-indigo-300"
          >
            #{tag}
          </a>
        ))
      }
      </div>
    </div>
  </article>
</Base>
