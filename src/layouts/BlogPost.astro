---
import Base from "@layouts/Base.astro";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";
import CalendarIcon from "@icons/CalendarIcon.astro";
import CategoryIcon from "@icons/CategoryIcon.astro";
import { Image } from "astro:assets";
import config from "@config/config.json";
import { slugify } from "@utils/slug";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, heroImage, categories, tags } =
  Astro.props;
---

<Base meta_title={title} description={description} image={heroImage} blogpost>
  <article>
    <div class="rounded-xl block overflow-hidden mb-8 shadow-sm">
      {
        heroImage && (
          <figure class="w-full h-auto max-h-[500px] object-cover relative">
            <Image
              class="w-full h-full object-cover"
              src={heroImage}
              alt={title}
              width={960}
              height={480}
              decoding="async"
              loading="lazy"
            />
          </figure>
        )
      }
    </div>
    <div class="md:col-10 text-center mb-12 max-w-3xl mx-auto">
      <div class="flex items-center justify-center gap-2 mb-4">
        {
          categories?.slice(0, 1).map((category) => (
            <a
              href={`/categories/${slugify(category)}`}
              class="px-3 py-1 text-xs font-semibold tracking-wide text-violet-600 uppercase bg-violet-50 rounded-full dark:bg-violet-900/30 dark:text-violet-300 hover:bg-violet-100 dark:hover:bg-violet-900/50 transition-colors"
            >
              {category}
            </a>
          ))
        }
      </div>
      
      <h1 class="text-3xl md:text-5xl font-extrabold font-heading text-gray-900 dark:text-white leading-tight mb-6">{title}</h1>
      
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500 dark:text-gray-400">
        <div class="flex items-center gap-2">
          <Image
            alt={config.author.name}
            class="h-8 w-8 rounded-full ring-2 ring-white dark:ring-gray-800"
            width={50}
            height={50}
            src={config.author.avatar}
            decoding="async"
            loading="lazy"
          />
          <span class="font-medium text-gray-900 dark:text-gray-200">{config.author.name}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <CalendarIcon class="w-4 h-4" />
          <FormattedDate date={pubDate} />
        </div>
      </div>
    </div>
    
    <div class="prose prose-lg prose-slate dark:prose-invert mx-auto">
      <slot />
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800">
      <div class="flex flex-wrap gap-2">
      {
        tags?.map((tag) => (
          <a
            href={`/tags/${slugify(tag)}`}
            class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-violet-100 hover:text-violet-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:text-violet-300 transition-colors"
          >
            #{tag}
          </a>
        ))
      }
      </div>
    </div>
  </article>
</Base>
