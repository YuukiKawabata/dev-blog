---
import Base from "@layouts/Base.astro";
import { getTaxonomy } from "@utils/getAllTags";

const allCategories = await getTaxonomy("blog", "categories");
const uniqueCategories = [...new Set(allCategories.map(item => item.slug))].map(slug => allCategories.find(cat => cat.slug === slug));
---

<Base meta_title="Categories">
  <section>
    <h1 class="font-heading text-3xl font-semibold tracking-tight sm:text-4xl">Categories</h1>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">カテゴリーから記事をたどる</p>

    <ul class="mt-10 divide-y divide-gray-200 border-t border-gray-200 dark:divide-gray-800 dark:border-gray-800">
      {
        uniqueCategories.map((category) => (
          <li>
            <a
              class="group flex items-center justify-between py-4 text-lg text-gray-700 transition-colors hover:text-indigo-700 dark:text-gray-300 dark:hover:text-indigo-300"
              href={`/categories/${category.slug}`}
              title={`View posts in the category: ${category.name}`}
            >
              <span class="capitalize">{category.name}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-gray-300 transition-all group-hover:translate-x-1 group-hover:text-indigo-500 dark:text-gray-600"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
