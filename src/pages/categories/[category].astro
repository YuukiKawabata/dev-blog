---
import Base from "@layouts/Base.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { getTaxonomy } from "@utils/getAllTags";
import { getSinglePage } from "@utils/getAllTags";
import { taxonomyFilter } from "@utils/getAllTags";
import { deslugify } from "@utils/slug";

export async function getStaticPaths() {
  const categories = await getTaxonomy("blog", "categories");

  return categories.map((category) => {
    return {
      params: { category: category.slug },
    };
  });
}

const { category } = Astro.params;

const posts = await getSinglePage("blog");
const filterByCategory = taxonomyFilter(posts, "categories", category);
---

<Base meta_title={`Category: ${deslugify(category)}`}>
  <p class="text-xs uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">Category</p>
  <h1 class="mt-2 font-heading text-3xl font-semibold capitalize tracking-tight sm:text-4xl">{deslugify(category)}</h1>

  <div class="mt-10 divide-y divide-gray-200 border-t border-gray-200 dark:divide-gray-800 dark:border-gray-800">
    {
      filterByCategory?.map((post) => (
        <article class="group py-6">
          <a href={`/blog/${post.slug}`} class="block">
            <div class="text-xs uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500">
              <FormattedDate date={post.data.pubDate} />
            </div>
            <h2 class="mt-2 font-heading text-xl font-semibold leading-snug text-gray-900 transition-colors group-hover:text-indigo-700 dark:text-white dark:group-hover:text-indigo-300">
              {post.data.title}
            </h2>
          </a>
        </article>
      ))
    }
  </div>
</Base>
