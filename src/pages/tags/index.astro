---
import Base from "@layouts/Base.astro";
import { getTaxonomy } from "@utils/getAllTags";

const tags = await getTaxonomy("blog", "tags");
---

<Base meta_title="Tags">
  <section>
    <h1 class="font-heading text-3xl font-semibold tracking-tight sm:text-4xl">Tags</h1>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">タグから記事をたどる</p>

    <ul class="mt-10 flex flex-wrap gap-x-5 gap-y-3">
      {
        tags.map((tag) => (
          <li>
            <a
              class="text-base text-gray-600 underline decoration-gray-300 decoration-1 underline-offset-4 transition-colors hover:text-indigo-700 hover:decoration-indigo-400 dark:text-gray-400 dark:decoration-gray-600 dark:hover:text-indigo-300"
              href={`/tags/${tag.slug}`}
              title={`View posts with the tag: ${tag.name}`}
            >
              {tag.name}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
