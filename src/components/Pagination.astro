---
import NextIcon from '@icons/NextIcon.astro';
import PrevIcon from '@icons/PrevIcon.astro';

const { length, currentPage, firstUrl, prevUrl, nextUrl } = Astro.props;
const paginationList = Array.from({ length }, (_, i) => i + 1);
---

<nav class="mt-16 border-t border-gray-200 pt-8 dark:border-gray-800">
  <ol class="flex justify-center gap-2 text-sm">
    {
      prevUrl ? (
        <li>
          <a
            href={prevUrl}
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-900 rtl:rotate-180 dark:text-gray-400 dark:hover:bg-gray-900 dark:hover:text-white"
          >
            <span class="sr-only">Prev Page</span>
            <PrevIcon />
          </a>
        </li>
      ) : null
    }
    {
      paginationList?.map((num) => (
        <li>
          <a
            href={`${firstUrl}${num == 1 ? '' : '' + num}`}
            class={`flex h-9 w-9 items-center justify-center rounded-md text-center transition-colors ${
              currentPage == num
                ? 'bg-gray-900 font-medium text-white dark:bg-white dark:text-gray-900'
                : 'text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-900 dark:hover:text-white'
            }`}
          >
            {num}
          </a>
        </li>
      ))
    }
    {
      nextUrl ? (
        <li>
          <a
            href={nextUrl}
            class="inline-flex h-9 w-9 items-center justify-center rounded-md text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-900 rtl:rotate-180 dark:text-gray-400 dark:hover:bg-gray-900 dark:hover:text-white"
          >
            <span class="sr-only">Next Page</span>
            <NextIcon />
          </a>
        </li>
      ) : null
    }
  </ol>
</nav>
