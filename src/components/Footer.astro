---
import config from "@config/config.json";
const year = new Date().getFullYear();
---

<footer class="mx-auto max-w-screen-lg px-4 sm:px-6 lg:px-8 mt-12 mb-8">
  <div class="border-t border-gray-200 dark:border-gray-800 pt-8">
    <div class="flex flex-col items-center justify-center gap-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        &copy; {year} <span class="font-semibold text-gray-700 dark:text-gray-200">{config.site.title}</span>. All rights reserved.
      </p>
      
      <!-- Optional: Add simple links or social icons here if desired in future -->
    </div>
  </div>
</footer>
