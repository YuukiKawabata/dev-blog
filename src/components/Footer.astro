---
import config from "@config/config.json";
const year = new Date().getFullYear();
---

<footer class="mx-auto mt-20 max-w-3xl px-5 pb-12 sm:px-6 lg:px-8">
  <div class="border-t border-gray-200 pt-8 dark:border-gray-800">
    <p class="text-xs tracking-wide text-gray-500 dark:text-gray-500">
      &copy; {year} {config.site.brand}
    </p>
  </div>
</footer>
