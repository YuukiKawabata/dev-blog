---
import { Image } from 'astro:assets';
import config from '@config/config.json';
import social from '@config/social';

const socialItems = social.networks;
---

<section class="border-b border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-3xl px-5 py-16 sm:px-6 sm:py-20 lg:px-8">
    <div class="flex flex-col-reverse gap-10 sm:flex-row sm:items-center sm:justify-between sm:gap-12">
      <div class="max-w-xl">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
          {config.site.brand}
        </p>

        <h1 class="mt-5 font-heading text-4xl font-semibold leading-[1.1] tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          複雑なものを、<br class="hidden sm:block" />のんびりと紐解く。
        </h1>

        <p class="mt-6 text-base leading-relaxed text-gray-600 dark:text-gray-400">
          {config.author.bio}
        </p>

        <div class="mt-8 flex items-center gap-5">
          {
            socialItems?.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 transition-colors hover:text-gray-900 dark:text-gray-500 dark:hover:text-white"
              >
                <span class="sr-only">{item.name}</span>
                <div class="h-5 w-5">
                  <Fragment set:html={item.svg} />
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="shrink-0">
        <Image
          src={config.author.avatar}
          alt={config.author.name}
          width={320}
          height={320}
          decoding="async"
          loading="eager"
          class="h-28 w-28 rounded-full border border-gray-200 object-cover sm:h-36 sm:w-36 dark:border-gray-800"
        />
      </div>
    </div>
  </div>
</section>
