---
import { Image } from 'astro:assets';
import config from '@config/config.json';
import social from '@config/social';

const socialItems = social.networks;
---

<section class="bg-white dark:bg-gray-900 overflow-hidden relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-violet-100/40 via-transparent to-transparent dark:from-violet-900/20 pointer-events-none"></div>
  
  <div class="mx-auto max-w-screen-lg px-4 py-12 sm:px-6 lg:px-8 lg:py-20 relative z-10">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-8 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
           <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
            <span class="block text-gray-900 dark:text-white">BAATA</span>
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-indigo-600 dark:from-violet-400 dark:to-indigo-400">
              Tech Note
            </span>
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl leading-relaxed">
            {config.author.bio}
          </p>
        </div>

        <div class="flex items-center gap-4">
          {
            socialItems?.map((item) => (
              <a 
                href={item.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center justify-center w-12 h-12 rounded-full bg-gray-50 text-gray-600 hover:bg-violet-50 hover:text-violet-600 hover:scale-110 transition-all duration-300 shadow-sm border border-gray-100 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-700 dark:hover:bg-gray-700 dark:hover:text-violet-400"
              >
                <span class="sr-only">{item.name}</span>
                <div class="w-5 h-5">
                    <Fragment set:html={item.svg} />
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="relative lg:col-span-1 hidden lg:block">
        <div class="relative w-full aspect-square max-w-sm mx-auto">
             <div class="absolute inset-0 bg-gradient-to-tr from-violet-200 to-indigo-200 rounded-full blur-3xl opacity-30 animate-pulse dark:from-violet-900 dark:to-indigo-900"></div>
             <!-- You can replace this with a real hero image or keep the avatar -->
             <Image
                src={config.author.avatar}
                alt={config.author.name}
                width={400}
                height={400}
                class="relative rounded-2xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500 border-4 border-white dark:border-gray-800 object-cover w-full h-full"
            />
        </div>
      </div>
    </div>
  </div>
</section>
